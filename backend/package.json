{
  "name": "bakery-backend",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.js",
    "build": "tsoa routes && tsc",
    "test": "vitest run",
    "migrate:up": "knex migrate:latest --knexfile knexfile.ts",
    "migrate:down": "knex migrate:rollback --knexfile knexfile.ts",
    "migrate:make": "knex migrate:make --knexfile knexfile.ts -x ts",
    "seed": "knex seed:run --knexfile knexfile.ts"
  },
  "dependencies": {
    "@tsoa/runtime": "^7.0.0-alpha.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "knex": "^3.2.9",
    "mysql2": "^3.22.3",
    "tsoa": "^7.0.0-alpha.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^25.6.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^2.0.0"
  }
}
